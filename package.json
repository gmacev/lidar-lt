{
    "name": "lidar-lt",
    "private": true,
    "version": "0.0.0",
    "description": "Interactive web application for exploring Lithuania's LiDAR point cloud data",
    "author": {
        "name": "Giedrius Macevičius",
        "email": "gmacev@gmail.com",
        "url": "https://github.com/gmacev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gmacev/lidar-lt"
    },
    "bugs": {
        "url": "https://github.com/gmacev/lt-open-data-sdk/issues"
    },
    "homepage": "https://github.com/gmacev/lt-open-data-sdk#readme",
    "keywords": [
        "lidar",
        "point-cloud",
        "potree",
        "lithuania",
        "3d-visualization",
        "geospatial",
        "react",
        "threejs"
    ],
    "engines": {
        "node": ">=20.19.0"
    },
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build && npm run sitemap",
        "sitemap": "npx tsx scripts/generate-sitemap.ts",
        "generate:map-style": "tsx scripts/generate-map-style.ts",
        "optimize:grid": "tsx scripts/optimize-grid.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
        "test:e2e": "playwright test --project=chromium --project=mobile-chromium",
        "test:e2e:headed": "playwright test --project=chromium --headed",
        "test:e2e:ui": "playwright test --ui --project=chromium --project=mobile-chromium",
        "test:e2e:live": "playwright test --project=live-chromium",
        "type-check": "tsc -b --noEmit",
        "check:circular": "dpdm --circular --no-warning --no-tree src/main.tsx",
        "check:unused": "knip",
        "check:all": "npm run type-check && npm run lint && npm run check:circular && npm run check:unused && npm run test:e2e",
        "preview": "vite preview",
        "serve": "npm run build && vite preview"
    },
    "dependencies": {
        "@mapbox/vector-tile": "^2.0.5",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-router": "^1.170.9",
        "@types/three": "^0.184.1",
        "@vis.gl/react-maplibre": "^8.1.1",
        "i18next": "^26.3.0",
        "i18next-browser-languagedetector": "^8.2.1",
        "lodash": "^4.18.1",
        "maplibre-gl": "^5.24.0",
        "pbf": "^4.0.2",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-helmet-async": "^3.0.0",
        "react-i18next": "^17.0.8",
        "tailwindcss": "^4.3.0",
        "three": "^0.184.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.61.1",
        "@rolldown/plugin-babel": "^0.2.0",
        "@tanstack/router-plugin": "^1.168.12",
        "@types/geojson": "^7946.0.16",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.12.4",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "dpdm": "^4.2.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-no-manual-memo": "^1.0.4",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "knip": "^6.14.2",
        "prettier": "^3.8.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14"
    },
    "overrides": {
        "react-helmet-async": {
            "react": "$react",
            "react-dom": "$react-dom"
        }
    }
}
